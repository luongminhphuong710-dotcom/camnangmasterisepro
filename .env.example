# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local-only demo CMS mode. Set true to edit local data in .local-demo/
# without touching Neon/production data.
CMS_LOCAL_DEMO=false

# Image hosting (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CMS auth
CMS_SESSION_SECRET=change-this-random-secret

# Bootstrap-only: used to seed the cms_users table the first time it's empty.
# Once accounts exist in Neon, these are ignored.
CMS_ADMIN_USER=admin
CMS_ADMIN_PASSWORD=admin123
CMS_USERS_JSON=[{"username":"super","password":"admin123","role":"super_admin"},{"username":"admin","password":"admin123","role":"admin"},{"username":"staff","password":"admin123","role":"employee"}]
